{
  "manifest_version": 3,
  "name": "Ash with Experts",
  "version": "0.1.0",
  "description": "Ash silently captures your therapy session and builds your context window automatically.",

  "permissions": [
    "tabCapture",
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "notifications"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*", "https://*.zoom.us/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Ash with Experts"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
